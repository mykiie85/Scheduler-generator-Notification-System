# Database
DATABASE_URL=postgresql://labuser:labpass@localhost:5432/labscheduler
POSTGRES_USER=labuser
POSTGRES_PASSWORD=labpass
POSTGRES_DB=labscheduler

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Server
API_PORT=3001
WEB_PORT=3000
NODE_ENV=development

# n8n
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# Notification stubs (no real keys needed)
WHATSAPP_API_URL=http://localhost:3001/api/stub/whatsapp
SMS_API_URL=http://localhost:3001/api/stub/sms
EMAIL_SMTP_HOST=stub
EMAIL_SMTP_PORT=587
EMAIL_FROM=noreply@labscheduler.local
