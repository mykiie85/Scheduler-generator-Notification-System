# ===========================================
# Lab Scheduler - Environment Variables
# ===========================================
# Copy this file to .env and fill in real values
# NEVER commit .env files with real credentials!

# Database
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=labscheduler
DATABASE_URL=postgresql://your_db_user:your_strong_password_here@localhost:5432/labscheduler

# Authentication
JWT_SECRET=generate_a_random_64_char_string_here
JWT_EXPIRES_IN=7d

# Server
API_PORT=3001
WEB_PORT=3000
NODE_ENV=development

# n8n Automation
N8N_PORT=5678
N8N_BASIC_AUTH_USER=your_n8n_admin_user
N8N_BASIC_AUTH_PASSWORD=your_n8n_admin_password

# n8n Webhook URLs (get these from your n8n instance)
N8N_WEEKLY_ALLOCATION_WEBHOOK_URL=
N8N_HOLIDAY_WEBHOOK_URL=
N8N_EVENT_WEBHOOK_URL=
N8N_ANNOUNCEMENT_WEBHOOK_URL=
N8N_ROSTER_WEBHOOK_URL=

# Webhook Security
WEBHOOK_API_KEY=generate_a_random_key_here

# Notification APIs
WHATSAPP_API_URL=
SMS_API_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=noreply@yourdomain.com
